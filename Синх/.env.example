# Логин/пароль от личного кабинета papasushi.goulash.tech (один аккаунт видит все филиалы)
GOULASH_USERNAME=
GOULASH_PASSWORD=

# ── Несколько филиалов (рекомендуется, если филиалов больше одного) ─────────
# Одна пара "department_id=webhook_url" на каждый филиал, через ";".
# department_id — найти в Network в DevTools при переключении филиала на goulash.
# webhook_url — берётся в Настройки → Интеграции → "Синхронизация выручки (вебхук)"
# на crmpapa.ru, для каждого филиала свой токен.
#
# Пример на 3 филиала (для 8 — просто добавьте ещё пары через ";"):
# GOULASH_SYNC_MAP=162=https://crmpapa.ru/api/revenue-webhook/tok1;165=https://crmpapa.ru/api/revenue-webhook/tok2;170=https://crmpapa.ru/api/revenue-webhook/tok3
GOULASH_SYNC_MAP=

# ── Время ожидания «Обещаем гостю» (необязательно) ───────────────────────────
# Тот же формат "department_id=webhook_url;...", те же department_id, что и в GOULASH_SYNC_MAP,
# но webhook_url — с Настройки → API → «Синхронизация времени ожидания» на crmpapa.ru
# (это ДРУГОЙ токен, не тот, что для выручки).
# Если не задать — время ожидания просто не отправляется, выручка продолжает работать как раньше.
GOULASH_WAITTIME_SYNC_MAP=

# ── Одиночный режим (только если филиал один) ───────────────────────────────
# Если GOULASH_SYNC_MAP задан — эти две переменные игнорируются.
GOULASH_DEPARTMENT_ID=
CRMPAPA_WEBHOOK_URL=

# Как часто опрашивать goulash в режиме постоянной работы (в секундах). По умолчанию 600 = 10 минут.
POLL_INTERVAL_SECONDS=600

# ── Заказы («Отчёт по заказам», необязательно) ───────────────────────────────
# Полная строка запроса страницы отчёта (всё после "?" в её адресе в браузере),
# с {date_from} и {date_to} вместо конкретных дат — их сам скрипт подставляет
# перед каждым запросом (формат ДД.ММ.ГГГГ). Уже готовое значение ниже — рабочий
# фильтр, который использовался при настройке (те же филиалы/статус/колонки,
# что и при ручной выгрузке) — менять не нужно, если набор филиалов не менялся.
# webhook_url — Настройки → API → «Синхронизация заказов (вебхук)» на crmpapa.ru
# (один токен сразу на все филиалы — разбор по филиалам делается по самим заказам).
GOULASH_ORDERS_QUERY_TEMPLATE=alert_mode=1&ReceiptsAll%5Bdepartment_by_ip%5D=0&ReceiptsAll%5Bid_agent%5D%5B%5D=158&ReceiptsAll%5Bid_agent%5D%5B%5D=157&ReceiptsAll%5Bid_agent%5D%5B%5D=163&ReceiptsAll%5Bid_agent%5D%5B%5D=155&ReceiptsAll%5Bid_agent%5D%5B%5D=156&ReceiptsAll%5Bid_agent%5D%5B%5D=161&ReceiptsAll%5Bid_agent%5D%5B%5D=164&ReceiptsAll%5BisCurrentDate%5D=0&ReceiptsAll%5BisCurrentDate%5D=1&ReceiptsAll%5Bdate_s%5D={date_from}&ReceiptsAll%5Bdate_do%5D={date_to}&needFullOrderListByGuest=&ReceiptsAll%5Breceipt_status%5D%5B%5D=30&ReceiptsAll%5Bstatus_ordering%5D=&yt13=%D0%A1%D1%84%D0%BE%D1%80%D0%BC%D0%B8%D1%80%D0%BE%D0%B2%D0%B0%D1%82%D1%8C&ReceiptsAll%5B_form_courier_routes%5D=&ReceiptsAll%5BpageSize%5D=1000&labels%5B%5D=code&labels%5B%5D=agentTitle&labels%5B%5D=apply_time&labels%5B%5D=time_delivery_promise&labels%5B%5D=orderTypeTitle&labels%5B%5D=actualPrepareTime&labels%5B%5D=actual_delivery_time&labels%5B%5D=promoeventPromocode&labels%5B%5D=total_summ_clear&labels%5B%5D=is_new_guest
CRMPAPA_ORDERS_WEBHOOK_URL=

# За сколько последних дней запрашивать заказы при каждом запуске (с запасом на
# случай, если заказ "дозреет" уже после первой загрузки — безопасно, повторная
# загрузка обновляет уже известный заказ, а не дублирует). По умолчанию 3 дня.
ORDERS_LOOKBACK_DAYS=3
