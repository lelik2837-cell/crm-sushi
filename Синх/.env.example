# Логин/пароль от личного кабинета papasushi.goulash.tech
GOULASH_USERNAME=
GOULASH_PASSWORD=

# ID подразделения (филиала) в goulash — 162 уже определён через Network в DevTools
GOULASH_DEPARTMENT_ID=162

# URL вебхука на crmpapa.ru — берётся в Настройки → Интеграции → "Синхронизация выручки (вебхук)"
# после создания токена для нужного филиала. Выглядит как:
# https://crmpapa.ru/api/revenue-webhook/<токен>
CRMPAPA_WEBHOOK_URL=

# Как часто опрашивать goulash в режиме постоянной работы (в секундах). По умолчанию 600 = 10 минут.
POLL_INTERVAL_SECONDS=600
